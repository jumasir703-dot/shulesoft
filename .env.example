# Database
DATABASE_URL="postgresql://user:password@localhost:5432/examdb?schema=public"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=4000
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"

# Mail (Nodemailer - e.g. Gmail SMTP or a transactional provider)
MAIL_HOST="smtp.example.com"
MAIL_PORT=587
MAIL_USER="no-reply@example.com"
MAIL_PASSWORD="change-me"
MAIL_FROM="Exam System <no-reply@example.com>"

# Allowed school email domains (comma separated) - teachers must register with these
ALLOWED_SCHOOL_EMAIL_DOMAINS="school.ac.ke"
