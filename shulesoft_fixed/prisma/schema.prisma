// ============================================================================
// SCHOOL EXAMINATION MANAGEMENT SYSTEM - PRISMA SCHEMA
// Multi-tenant SaaS supporting CBC/CBE Grade 10 + Form 3/4 (8-4-4)
// Kenya curriculum transition ready
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum SystemRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum AccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum CurriculumType {
  CBC_GRADE10 // Competency Based Curriculum / CBE Senior School Grade 10
  FORM_3 // 8-4-4 legacy system
  FORM_4 // 8-4-4 legacy system
}

enum Gender {
  MALE
  FEMALE
}

enum ExamType {
  CAT_1
  CAT_2
  MIDTERM
  END_TERM
  MOCK
  JOINT
  ANNUAL
}

enum ExamStatus {
  DRAFT // admin created, not yet open for marks entry
  OPEN // teachers can enter/edit marks
  SUBMITTED // teachers submitted, awaiting admin review
  CLOSED // marks entry window closed
  APPROVED // admin approved, not yet visible to students/parents
  PUBLISHED // visible to students/parents
  LOCKED // frozen, no further edits allowed even by admin (requires audit override)
}

enum MarkStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum TeacherAssignmentRole {
  SUBJECT_TEACHER
  CLASS_TEACHER
}

enum NotificationType {
  REGISTRATION_APPROVAL
  PASSWORD_RESET
  EXAM_PUBLISHED
  REPORT_CARD_AVAILABLE
  MISSING_MARKS
  DEADLINE_REMINDER
  GENERAL
}

enum NotificationChannel {
  EMAIL
  SMS
  IN_APP
}

enum AuditAction {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
  MARKS_UPLOADED
  MARKS_EDITED
  RESULTS_PUBLISHED
  ACCOUNT_APPROVED
  ACCOUNT_SUSPENDED
  PASSWORD_RESET
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

// ============================================================================
// CORE IDENTITY / AUTH
// ============================================================================

model School {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique // short school code, e.g. TESTY-001
  county        String?
  subCounty     String?
  logoUrl       String?
  stampUrl      String?
  principalName String?
  contactEmail  String?
  contactPhone  String?
  isActive      Boolean  @default(true)
  subscription  SchoolSubscription?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         User[]
  academicYears AcademicYear[]
  classes       ClassLevel[]
  subjects      Subject[]
  gradingScales GradingScale[]
  rubrics       CompetencyRubric[]
  auditLogs     AuditLog[]

  @@map("schools")
}

model SchoolSubscription {
  id        String   @id @default(cuid())
  schoolId  String   @unique
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  plan      String   @default("FREE") // FREE, STANDARD, PREMIUM
  seats     Int      @default(50)
  startedAt DateTime @default(now())
  expiresAt DateTime?
  isActive  Boolean  @default(true)

  @@map("school_subscriptions")
}

// Base auth identity. Role-specific profile data lives in Teacher / Student / Parent / SchoolAdmin.
model User {
  id                String        @id @default(cuid())
  email             String        @unique
  passwordHash      String
  role              SystemRole
  status            AccountStatus @default(PENDING)
  isEmailVerified   Boolean       @default(false)
  twoFactorEnabled  Boolean       @default(false)
  twoFactorSecret   String?
  lastLoginAt       DateTime?
  schoolId          String? // null for SUPER_ADMIN
  school            School?       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  teacherProfile    Teacher?
  studentProfile    Student?
  parentProfile     Parent?
  adminProfile      SchoolAdmin?

  refreshTokens     RefreshToken[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  passwordResets    PasswordResetToken[]
  emailVerifications EmailVerificationToken[]

  @@index([schoolId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@map("email_verification_tokens")
}

// ============================================================================
// ROLE PROFILES
// ============================================================================

model SchoolAdmin {
  id       String @id @default(cuid())
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName String
  phone    String?

  @@map("school_admins")
}

model Teacher {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName       String
  employeeNumber String
  nationalId     String
  phone          String
  tscNumber      String?
  approvedAt     DateTime?
  approvedById   String? // SchoolAdmin userId who approved

  assignments    TeacherAssignment[]
  classTeacherOf Stream[]            @relation("ClassTeacher")
  marksEntered   Mark[]              @relation("MarkEnteredBy")

  @@unique([employeeNumber, userId])
  @@map("teachers")
}

model Student {
  id                String   @id @default(cuid())
  userId            String?  @unique // nullable: students may be created before portal access is issued
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  schoolId          String
  admissionNumber   String
  fullName          String
  gender            Gender
  dateOfBirth       DateTime?
  photoUrl          String?
  currentStreamId   String?
  currentStream     Stream?  @relation(fields: [currentStreamId], references: [id])
  curriculumType    CurriculumType
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  parents           ParentStudent[]
  marks             Mark[]
  reportCards       ReportCard[]
  attendanceRecords Attendance[]
  cbcAssessments    CbcAssessment[]
  promotions        StudentPromotion[]

  @@unique([schoolId, admissionNumber])
  @@index([schoolId])
  @@map("students")
}

model Parent {
  id       String @id @default(cuid())
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName String
  phone    String

  children ParentStudent[]

  @@map("parents")
}

model ParentStudent {
  id        String  @id @default(cuid())
  parentId  String
  parent    Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  relation  String? // e.g. "Mother", "Father", "Guardian"

  @@unique([parentId, studentId])
  @@map("parent_students")
}

// ============================================================================
// SCHOOL STRUCTURE
// School -> AcademicYear -> Term -> ClassLevel -> Stream -> Subjects -> Students
// ============================================================================

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  year      Int // e.g. 2026
  isActive  Boolean  @default(false)

  terms     Term[]
  promotions StudentPromotion[]

  @@unique([schoolId, year])
  @@map("academic_years")
}

model Term {
  id             String       @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  name           String // "Term 1", "Term 2", "Term 3"
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean      @default(false)

  exams          Exam[]
  attendance     Attendance[]

  @@unique([academicYearId, name])
  @@map("terms")
}

model ClassLevel {
  id             String         @id @default(cuid())
  schoolId       String
  school         School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name           String // "Grade 10", "Form 3", "Form 4"
  curriculumType CurriculumType

  streams        Stream[]

  @@unique([schoolId, name])
  @@map("class_levels")
}

model Stream {
  id           String     @id @default(cuid())
  classLevelId String
  classLevel   ClassLevel @relation(fields: [classLevelId], references: [id], onDelete: Cascade)
  name         String // "East", "West", "Gold"
  classTeacherId String?
  classTeacher Teacher?   @relation("ClassTeacher", fields: [classTeacherId], references: [id])

  students        Student[]
  assignments     TeacherAssignment[]
  examSubjects    ExamSubject[]
  reportCards     ReportCard[]
  promotionsFrom  StudentPromotion[] @relation("FromStream")
  promotionsTo    StudentPromotion[] @relation("ToStream")

  @@unique([classLevelId, name])
  @@map("streams")
}

model Subject {
  id             String         @id @default(cuid())
  schoolId       String
  school         School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name           String
  code           String
  curriculumType CurriculumType
  isCore         Boolean        @default(true)

  assignments    TeacherAssignment[]
  examSubjects   ExamSubject[]
  marks          Mark[]
  cbcAssessments CbcAssessment[]

  @@unique([schoolId, code, curriculumType])
  @@map("subjects")
}

// Assigns a teacher to teach a subject to a specific stream (and optionally as class teacher)
model TeacherAssignment {
  id        String                 @id @default(cuid())
  teacherId String
  teacher   Teacher                @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject                @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  streamId  String
  stream    Stream                 @relation(fields: [streamId], references: [id], onDelete: Cascade)
  role      TeacherAssignmentRole  @default(SUBJECT_TEACHER)
  createdAt DateTime               @default(now())

  @@unique([teacherId, subjectId, streamId])
  @@map("teacher_assignments")
}

model StudentPromotion {
  id             String       @id @default(cuid())
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  fromStreamId   String?
  fromStream     Stream?      @relation("FromStream", fields: [fromStreamId], references: [id])
  toStreamId     String
  toStream       Stream       @relation("ToStream", fields: [toStreamId], references: [id])
  promotedAt     DateTime     @default(now())
  promotedById   String // SchoolAdmin userId

  @@map("student_promotions")
}

// ============================================================================
// EXAMINATIONS & MARKS
// ============================================================================

model Exam {
  id           String     @id @default(cuid())
  termId       String
  term         Term       @relation(fields: [termId], references: [id], onDelete: Cascade)
  name         String
  examType     ExamType
  totalMarks   Int        @default(100)
  weighting    Float      @default(1.0) // contribution weight toward term average
  openDate     DateTime
  closeDate    DateTime
  publishDate  DateTime?
  status       ExamStatus @default(DRAFT)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  examSubjects ExamSubject[]
  marks        Mark[]
  reportCards  ReportCard[]

  @@map("exams")
}

// Links an exam to the subjects/streams it covers, so per-stream/per-subject deadlines & weighting are possible
model ExamSubject {
  id         String  @id @default(cuid())
  examId     String
  exam       Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  subjectId  String
  subject    Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  streamId   String
  stream     Stream  @relation(fields: [streamId], references: [id], onDelete: Cascade)
  totalMarks Int     @default(100)

  @@unique([examId, subjectId, streamId])
  @@map("exam_subjects")
}

model Mark {
  id            String     @id @default(cuid())
  examId        String
  exam          Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId     String
  subject       Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  rawScore      Float // score as entered, out of exam_subjects.totalMarks
  grade         String? // computed via GradingScale, e.g. "A-"
  points        Float? // mean-points equivalent, computed
  status        MarkStatus @default(DRAFT)
  enteredById   String
  enteredBy     Teacher    @relation("MarkEnteredBy", fields: [enteredById], references: [id])
  isAbsent      Boolean    @default(false)
  remarks       String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([examId, studentId, subjectId])
  @@index([examId, subjectId])
  @@map("marks")
}

// ============================================================================
// GRADING (Form 3/4 - KCSE style)
// ============================================================================

model GradingScale {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name     String @default("Default KCSE Scale")
  isActive Boolean @default(true)

  bands    GradeBand[]

  @@map("grading_scales")
}

model GradeBand {
  id             String       @id @default(cuid())
  gradingScaleId String
  gradingScale   GradingScale @relation(fields: [gradingScaleId], references: [id], onDelete: Cascade)
  grade          String // "A", "A-", "B+", ...
  minScore       Float
  maxScore       Float
  points         Float // mean points, e.g. A=12, A-=11 ...

  @@unique([gradingScaleId, grade])
  @@map("grade_bands")
}

// ============================================================================
// CBC / CBE COMPETENCY-BASED ASSESSMENT (Grade 10)
// ============================================================================

model CompetencyRubric {
  id                  String  @id @default(cuid())
  schoolId            String
  school              School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subjectName         String
  learningOutcome     String
  competencyIndicator String
  levelName           String // e.g. "Exceeding Expectation", "Meeting Expectation", "Approaching", "Below"
  levelValue          Int // ordinal 1-4 for calculation
  descriptor          String

  @@map("competency_rubrics")
}

model CbcAssessment {
  id                     String   @id @default(cuid())
  studentId              String
  student                Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId              String
  subject                Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  termId                 String
  learningOutcome        String
  competencyIndicator    String
  achievementLevel       String // matches CompetencyRubric.levelName
  achievementLevelValue  Int
  performanceDescriptor  String
  teacherComment         String?
  growthRecommendation   String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([studentId, termId])
  @@map("cbc_assessments")
}

// ============================================================================
// REPORT CARDS
// ============================================================================

model ReportCard {
  id                 String   @id @default(cuid())
  studentId          String
  student            Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examId             String
  exam               Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  streamId           String
  stream             Stream   @relation(fields: [streamId], references: [id], onDelete: Cascade)

  totalMarks         Float?
  averageScore       Float?
  meanGrade          String?
  meanPoints         Float?
  streamPosition     Int?
  classPosition      Int?
  overallRank        Int?
  division           String? // KCSE-era division, optional
  overallAchievement String? // CBC overall competency achievement
  attendanceSummary  String?
  principalRemark    String?
  classTeacherRemark String?

  qrCodeToken        String   @unique @default(cuid())
  pdfUrl             String?
  version            Int      @default(1)
  isPublished        Boolean  @default(false)
  publishedAt        DateTime?
  generatedAt        DateTime @default(now())

  entries            ReportCardEntry[]

  @@unique([studentId, examId])
  @@map("report_cards")
}

// Per-subject line item snapshot on the report card (denormalized for stable historical record)
model ReportCardEntry {
  id            String     @id @default(cuid())
  reportCardId  String
  reportCard    ReportCard @relation(fields: [reportCardId], references: [id], onDelete: Cascade)
  subjectName   String
  score         Float?
  grade         String?
  points        Float?
  subjectRank   Int?
  teacherRemark String?

  @@map("report_card_entries")
}

// ============================================================================
// ATTENDANCE
// ============================================================================

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  termId    String
  term      Term             @relation(fields: [termId], references: [id], onDelete: Cascade)
  date      DateTime
  status    AttendanceStatus

  @@unique([studentId, date])
  @@index([termId])
  @@map("attendance")
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

model Notification {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  title     String
  message   String
  isRead    Boolean             @default(false)
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

// ============================================================================
// AUDIT LOGS
// ============================================================================

model AuditLog {
  id         String      @id @default(cuid())
  schoolId   String?
  school     School?     @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     AuditAction
  entityType String? // e.g. "Mark", "Exam", "ReportCard"
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  @@index([schoolId, createdAt])
  @@index([userId])
  @@map("audit_logs")
}
